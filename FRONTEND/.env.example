# ─────────────────────────────────────────────────────────────
# Find My Parking — Frontend Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Backend API URL ───────────────────────────────────────────
# The base URL of your running backend server (no trailing slash)
VITE_API_URL=http://localhost:3001

# ── Razorpay Payment Gateway ──────────────────────────────────
# Your Razorpay KEY_ID (public key — safe to use in frontend)
# Get it from: https://dashboard.razorpay.com/app/keys
# Use rzp_test_... for test mode, rzp_live_... for production
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
