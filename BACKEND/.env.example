# ─────────────────────────────────────────────────────────────
# Find My Parking — Backend Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/findmyparking
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/findmyparking
MONGO_URI=mongodb://localhost:27017/findmyparking

# ── JWT Authentication ────────────────────────────────────────
# Use a long, random string — at least 32 characters
JWT_SECRET=your_super_secret_jwt_key_here

# ── Razorpay Payment Gateway ──────────────────────────────────
# Get these from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_SECRET=your_razorpay_secret_here

# ── Admin Debug Mode (optional) ───────────────────────────────
# Set to "true" to enable verbose admin login logging
DEBUG_ADMIN_LOGIN=false

# ── Client URLs (for CORS, optional) ─────────────────────────
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
